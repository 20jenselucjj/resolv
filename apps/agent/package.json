{
  "name": "resolv-agent",
  "version": "1.0.0",
  "description": "Resolv ITSM Agent for Windows",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch & electron dist/main.js",
    "build": "tsc",
    "start": "electron dist/main.js",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron": "^42.3.3",
    "node-av": "^5.2.4",
    "node-screenshots": "^0.2.8",
    "screenshot-desktop": "^1.15.4",
    "socket.io-client": "^4.7.0",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.resolv.agent",
    "productName": "Resolv Agent",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "renderer/**/*"
    ],
    "extraResources": []
  }
}
